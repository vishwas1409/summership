PORT=3000
NODE_ENV=production

# Database Configuration (MySQL)
# Local / Hostinger:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=hackathon_selection

# Railway (auto-provided when MySQL service is linked):
# MYSQLHOST=...
# MYSQLPORT=...
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=...
# Or use a single URL:
# MYSQL_URL=mysql://user:password@host:port/database

# Security Keys
SESSION_SECRET=super_secret_session_key_here

# Admin Portal Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_secure_password
