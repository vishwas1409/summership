<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png" />
    <link rel="stylesheet" href="/styles/main.css?v=<%= assetVersion %>" />
    <!-- jsPDF Library for client-side PDF generation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
      .claim-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
        gap: 32px;
        align-items: start;
        margin-top: 32px;
      }
      
      .certificate-card {
        padding: 24px;
        border-radius: var(--radius-xl);
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
        gap: 20px;
        transition: border-color 0.3s ease, background 0.3s ease;
      }

      .certificate-card.active {
        background: linear-gradient(135deg, rgba(140, 82, 255, 0.03) 0%, rgba(16, 185, 129, 0.03) 100%);
        border-color: rgba(140, 82, 255, 0.2);
      }

      .claim-info-card {
        padding: 24px;
        border-radius: var(--radius-xl);
        background: rgba(255, 255, 255, 0.01);
        border: 1px dashed rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        gap: 16px;
        justify-content: center;
        align-items: center;
        min-height: 240px;
        text-align: center;
      }

      .claim-placeholder-text {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.6;
        max-width: 320px;
      }

      .fetch-loader {
        display: none;
        justify-content: center;
        align-items: center;
        gap: 10px;
        color: var(--brand-deep);
        font-weight: 700;
      }

      .fetch-loader::after {
        content: "";
        width: 24px;
        height: 24px;
        border: 3px solid rgba(140, 82, 255, 0.1);
        border-top-color: var(--brand-deep);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      .cert-preview-wrapper {
        position: relative;
        width: 100%;
        margin: 0 auto;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
        background: #000000;
        display: none;
        animation: fadeIn 0.5s ease-out forwards;
      }

      #cert-canvas {
        display: block;
        width: 100%;
        height: auto;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .action-row-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 10px;
      }

      .action-row-buttons .primary-button {
        width: 100%;
      }

      .linkedin-share-button {
        background: linear-gradient(135deg, #0a66c2 0%, #0077b5 100%) !important;
        border: none !important;
        color: #ffffff !important;
        box-shadow: 0 6px 20px rgba(10, 102, 194, 0.25) !important;
        grid-column: span 2;
      }

      .linkedin-share-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(10, 102, 194, 0.35) !important;
      }

      @media (max-width: 980px) {
        .claim-layout {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <header class="site-header">
        <a href="/claim-certificate" class="brand">
          <span class="brand-badge brand-badge-logo">
            <img src="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png" alt="GradSkills logo" class="brand-badge-image" />
          </span>
          <span>
            <strong>GradSkills</strong>
            <small>Summership E-Certificate Portal</small>
          </span>
        </a>
        <div class="header-status" style="margin-left: auto;">
          <span class="header-dot" style="background-color: #10b981;"></span>
          <span style="color: #10b981; font-weight: 700;">GradSkills Certified</span>
        </div>
      </header>

      <%- include("partials/flash") %>

      <section class="hero hero-home" style="margin-bottom: 8px;">
        <div class="hero-copy">
          <div class="hero-logos-row" style="justify-content: center;">
            <img src="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png" alt="GradSkills logo" class="hero-logo-mark" style="height: 64px; width: auto;" />
          </div>
          <p class="eyebrow" style="color: var(--brand-deep); font-weight: 800; letter-spacing: 0.1em;">SUMMERSHIP CHALLENGE 2026</p>
          <div class="hero-banner-pill" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2);">Official E-Certificate Portal</div>
          <h1>Claim Your Official <span class="hero-highlight">Participation E-Certificate</span></h1>
          <p class="hero-text" style="max-width: 65ch; margin: 16px auto 0;">
            Congratulations on securing your team selection! Verify your registered mobile number below to instantly generate, customize, and download your accredited GradSkills participation certificate.
          </p>
        </div>
      </section>

      <div class="claim-layout">
        <!-- Certificate Preview Column -->
        <section class="certificate-card" id="cert-card-shell">
          <div class="controls-head" style="margin-bottom: 8px;">
            <div>
              <p class="eyebrow">Certificate Viewport</p>
              <h2>Official E-Certificate Preview</h2>
            </div>
          </div>

          <div class="claim-info-card" id="preview-placeholder">
            <span style="font-size: 3rem; filter: drop-shadow(0 0 10px rgba(255,255,255,0.05));">🎓</span>
            <strong style="color: #ffffff; font-size: 1.15rem; margin-top: 8px;">Verification Required</strong>
            <p class="claim-placeholder-text">
              Enter your registered 10-digit phone number in the portal form to verify your selection lock and automatically generate your customized E-Certificate.
            </p>
          </div>

          <div class="fetch-loader" id="loader-spinner" style="margin: 60px 0;">
            <span>Retrieving locked selection details...</span>
          </div>

          <!-- Dynamic Certificate Render Area -->
          <div class="cert-preview-wrapper" id="cert-wrapper">
            <canvas id="cert-canvas"></canvas>
          </div>
        </section>

        <!-- Claim Controls Column -->
        <aside class="stack-form" style="display: flex; flex-direction: column; gap: 20px;">
          <section class="controls-card" style="margin-top: 0; padding: 24px;">
            <div class="controls-head" style="margin-bottom: 20px;">
              <div>
                <p class="eyebrow">Verification Form</p>
                <h2>Claim Credentials</h2>
              </div>
            </div>

            <label style="display: flex; flex-direction: column; gap: 8px; font-weight: 700; color: var(--muted); font-size: 0.9rem;">
              REGISTERED MOBILE NUMBER
              <input 
                type="tel" 
                name="mobileNumber" 
                id="claim-mobile-input"
                placeholder="Enter 10-digit registered number" 
                maxlength="10"
                style="width: 100%; padding: 14px; border-radius: var(--radius-md); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-size: 1rem; transition: border-color 0.2s;"
                required 
              />
            </label>

            <!-- Customization Controls (Hidden by default, unlocked upon valid phone number verification) -->
            <div id="customizer-options" style="display: none; flex-direction: column; gap: 16px; margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 20px; animation: fadeIn 0.4s ease-out forwards;">
              <span class="selection-panel-label" style="background: rgba(16, 185, 129, 0.12); color: #10b981; font-weight: 800; font-size: 0.8rem; padding: 4px 8px; border-radius: 6px; width: fit-content; margin-bottom: 4px;">Selection Locked Successfully</span>
              
              <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: var(--radius-md); padding: 16px; margin-bottom: 8px;">
                <span style="font-size: 0.76rem; color: var(--muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em;">LOCKED PROBLEM STATEMENT</span>
                <h4 id="selection-title" style="color: #ffffff; font-size: 0.98rem; margin: 4px 0 2px; font-weight: 700; line-height: 1.4;">Problem Statement Title</h4>
                <p id="selection-team" style="color: var(--brand-deep); font-size: 0.85rem; font-weight: 800; margin: 0;">Team: Name</p>
              </div>

              <label style="display: flex; flex-direction: column; gap: 8px; font-weight: 700; color: var(--muted); font-size: 0.88rem;">
                NAME DISPLAY MODE
                <select id="cert-name-display" style="width: 100%; padding: 12px; border-radius: var(--radius-md); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #fff; font-size: 0.92rem;">
                  <option value="team" selected>Team Name (Group Representation)</option>
                  <option value="leader">Email Address (Individual ID)</option>
                </select>
              </label>

              <label style="display: flex; flex-direction: column; gap: 8px; font-weight: 700; color: var(--muted); font-size: 0.88rem;">
                CALLIGRAPHY STYLE
                <select id="cert-font-style" style="width: 100%; padding: 12px; border-radius: var(--radius-md); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #fff; font-size: 0.92rem;">
                  <option value="Montserrat" selected>Modern Corporate (Sans-Serif)</option>
                  <option value="Great Vibes">Classic Calligraphy (Script)</option>
                  <option value="Playfair Display">Elegant Editorial (Serif)</option>
                </select>
              </label>

              <div class="action-row-buttons">
                <button type="button" id="download-jpg-btn" class="primary-button" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none;">
                  💾 Download JPG
                </button>
                <button type="button" id="download-pdf-btn" class="secondary-button" style="border: 1px solid rgba(255,255,255,0.15);">
                  📄 Download PDF
                </button>
                <button type="button" id="linkedin-btn" class="primary-button linkedin-share-button">
                  🚀 Share E-Certificate on LinkedIn
                </button>
              </div>
            </div>
          </section>
        </aside>
      </div>
    </div>

    <!-- Hidden Template Image Loader for Canvas Engine -->
    <img id="cert-template-img" src="/images/certificate-template.jpg" style="display: none;" />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const mobileInput = document.getElementById("claim-mobile-input");
        const placeholderMsg = document.getElementById("preview-placeholder");
        const loaderSpinner = document.getElementById("loader-spinner");
        const certWrapper = document.getElementById("cert-wrapper");
        const certCanvas = document.getElementById("cert-canvas");
        const certTemplateImg = document.getElementById("cert-template-img");
        
        const certCardShell = document.getElementById("cert-card-shell");
        const customizerOptions = document.getElementById("customizer-options");
        const selectionTitle = document.getElementById("selection-title");
        const selectionTeam = document.getElementById("selection-team");
        
        const certNameDisplaySelect = document.getElementById("cert-name-display");
        const certFontStyleSelect = document.getElementById("cert-font-style");
        
        const downloadJpgBtn = document.getElementById("download-jpg-btn");
        const downloadPdfBtn = document.getElementById("download-pdf-btn");
        const linkedinBtn = document.getElementById("linkedin-btn");

        let participantLeaderName = "";
        let participantTeamName = "";
        let lockedProblemTitle = "";

        // Preload premium Google Fonts dynamically for Canvas drawing compatibility
        const googleFonts = [
          { name: "Great Vibes", url: "https://fonts.gstatic.com/s/greatvibes/v15/RWmMoKHY3JJDZdOW9tE1746u.woff2" },
          { name: "Playfair Display", url: "https://fonts.gstatic.com/s/playfairdisplay/v37/nuFvD7K413qaH78BmcgYVEvt2I1qBFhcGy5z.woff2" },
          { name: "Montserrat", url: "https://fonts.gstatic.com/s/montserrat/v26/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2" }
        ];

        async function loadCustomFonts() {
          for (const f of googleFonts) {
            try {
              const font = new FontFace(f.name, `url(${f.url})`);
              await font.load();
              document.fonts.add(font);
            } catch (err) {
              console.warn("Failed to load Google Font: " + f.name, err);
            }
          }
        }

        loadCustomFonts();

        function isValidMobile(num) {
          return /^[6-9]\d{9}$/.test(num);
        }

        function drawCertificate() {
          if (!certTemplateImg.complete) {
            certTemplateImg.onload = drawCertificate;
            return;
          }

          const ctx = certCanvas.getContext("2d");
          const width = certTemplateImg.naturalWidth;
          const height = certTemplateImg.naturalHeight;
          
          certCanvas.width = width;
          certCanvas.height = height;

          // Draw certificate template base
          ctx.drawImage(certTemplateImg, 0, 0, width, height);

          // Custom name logic selection
          const isTeam = certNameDisplaySelect.value === "team";
          const displayName = isTeam ? participantTeamName : participantLeaderName;

          if (!displayName) return;

          const selectedFont = certFontStyleSelect.value;
          let fontSizeMultiplier = 0.045; // Default percentage of canvas width for dynamic scaling

          if (selectedFont === "Great Vibes") {
            fontSizeMultiplier = 0.06;
          }

          const fontSize = Math.floor(width * fontSizeMultiplier);
          const weight = selectedFont === "Great Vibes" ? "normal" : "bold";

          ctx.font = `${weight} ${fontSize}px '${selectedFont}', sans-serif`;
          ctx.fillStyle = "#111827"; // Signature dark typography matching the credentials design
          ctx.textAlign = "center";
          ctx.textBaseline = "bottom";

          const x = width / 2;
          const y = height * 0.465; // Coordinate line coordinates centered horizontally on the line

          ctx.fillText(displayName, x, y);
        }

        async function fetchLockedSelection(mobileNumber) {
          if (!isValidMobile(mobileNumber)) {
            resetView("Please enter a valid 10-digit registered mobile number.");
            return;
          }

          // Show loader spinner
          placeholderMsg.style.display = "none";
          certWrapper.style.display = "none";
          loaderSpinner.style.display = "flex";
          certCardShell.classList.remove("active");
          customizerOptions.style.display = "none";

          try {
            const response = await fetch(`/api/fetch-selection?mobileNumber=${encodeURIComponent(mobileNumber)}`);
            const data = await response.json();

            loaderSpinner.style.display = "none";

            if (data.success) {
              // Set variables
              participantLeaderName = data.leaderName;
              participantTeamName = data.teamName;
              lockedProblemTitle = data.title;

              // Update control text
              selectionTitle.textContent = lockedProblemTitle;
              selectionTeam.textContent = `Team: ${participantTeamName}`;

              // Unlock layouts
              certWrapper.style.display = "block";
              certCardShell.classList.add("active");
              customizerOptions.style.display = "flex";

              // Draw canvas
              drawCertificate();
            } else {
              resetView(data.message);
            }
          } catch (error) {
            console.error("AJAX Lookup Error:", error);
            loaderSpinner.style.display = "none";
            resetView("Server connection error. Please verify your phone number and try again.");
          }
        }

        function resetView(errorMsg) {
          participantLeaderName = "";
          participantTeamName = "";
          lockedProblemTitle = "";

          certWrapper.style.display = "none";
          certCardShell.classList.remove("active");
          customizerOptions.style.display = "none";
          placeholderMsg.style.display = "flex";

          placeholderMsg.innerHTML = `
            <span style="font-size: 3rem; filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.15));">⚠️</span>
            <strong style="color: #ef4444; font-size: 1.15rem; margin-top: 8px;">Verification Locked</strong>
            <p class="claim-placeholder-text" style="color: var(--muted);">${errorMsg}</p>
          `;
        }

        // Add real-time phone number entry tracking
        mobileInput.addEventListener("input", (e) => {
          const value = e.target.value.trim();
          if (value.length === 10) {
            localStorage.setItem("cert_claim_mobile", value);
            fetchLockedSelection(value);
          } else {
            resetView("Enter your registered 10-digit phone number in the portal form to verify your selection lock and automatically generate your customized E-Certificate.");
          }
        });

        // Pull cached mobile number if available
        if (!mobileInput.value.trim() && localStorage.getItem("cert_claim_mobile")) {
          mobileInput.value = localStorage.getItem("cert_claim_mobile");
        }

        if (mobileInput.value.trim().length === 10) {
          fetchLockedSelection(mobileInput.value.trim());
        }

        // Select changes redraw canvas dynamically
        certFontStyleSelect.addEventListener("change", drawCertificate);
        certNameDisplaySelect.addEventListener("change", drawCertificate);

        // JPG Download Action
        downloadJpgBtn.addEventListener("click", () => {
          const name = (certNameDisplaySelect.value === "team" ? participantTeamName : participantLeaderName) || "E-Certificate";
          const link = document.createElement("a");
          link.href = certCanvas.toDataURL("image/jpeg", 1.0);
          link.download = `GradSkills_Summership_Certificate_${name.replace(/\s+/g, '_')}.jpg`;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
        });

        // PDF Download Action
        downloadPdfBtn.addEventListener("click", () => {
          const name = (certNameDisplaySelect.value === "team" ? participantTeamName : participantLeaderName) || "E-Certificate";
          const { jsPDF } = window.jspdf;
          const pdf = new jsPDF({
            orientation: "landscape",
            unit: "mm",
            format: "a4"
          });
          const imgData = certCanvas.toDataURL("image/jpeg", 1.0);
          pdf.addImage(imgData, "JPEG", 0, 0, 297, 210);
          pdf.save(`GradSkills_Summership_Certificate_${name.replace(/\s+/g, '_')}.pdf`);
        });

        // LinkedIn sharing URL composer
        linkedinBtn.addEventListener("click", () => {
          const isTeam = certNameDisplaySelect.value === "team";
          const name = isTeam ? participantTeamName : participantLeaderName;
          
          const postText = `I am excited to share that I have locked my problem statement and claimed my official participation E-Certificate for the GradSkills Summership Challenge 2026! 🚀🎓 

We are working on some highly impactful solutions for our selected problem: "${lockedProblemTitle}". Can't wait to learn, collaborate, and build with my team! 💡💻

Thank you @GradSkills for this awesome opportunity! 🌟🏆

#GradSkills #Summership2026 #Hackathon #WebDevelopment #CodingChallenge #Internship`;

          const shareUrl = `https://www.linkedin.com/feed/?shareActive=true&text=${encodeURIComponent(postText)}`;
          window.open(shareUrl, "_blank");
        });
      });
    </script>
  </body>
</html>
