<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/main.css?v=<%= assetVersion %>" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
        width: 100%;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #020617;
        color: #f8fafc;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      /* ─── NAV ─────────────────────────────────────────────── */
      .cert-nav {
        width: 100%;
        padding: 0 32px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(2, 6, 23, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .cert-nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }

      .cert-nav-logo {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        object-fit: cover;
        filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.4));
      }

      .cert-nav-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: #f8fafc;
        letter-spacing: -0.01em;
      }

      .cert-nav-sub {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.35);
        font-weight: 500;
        padding-left: 10px;
        margin-left: 10px;
        border-left: 1px solid rgba(255, 255, 255, 0.1);
      }

      /* ─── FULL-PAGE BACKGROUND ────────────────────────────── */
      .cert-page {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        position: relative;
        overflow: hidden;
      }

      /* Background gradient blobs */
      .cert-page::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 800px 500px at 50% 0%, rgba(139, 92, 246, 0.08) 0%, transparent 70%),
          radial-gradient(ellipse 600px 400px at 80% 80%, rgba(99, 102, 241, 0.05) 0%, transparent 60%);
        pointer-events: none;
      }

      /* Subtle dot-grid background */
      .cert-page::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(139, 92, 246, 0.06) 1px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
      }

      /* ─── MAIN CARD ───────────────────────────────────────── */
      .cert-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 520px;
        background: rgba(8, 12, 30, 0.75);
        border: 1px solid rgba(139, 92, 246, 0.18);
        border-radius: 28px;
        padding: 52px 48px;
        backdrop-filter: blur(32px);
        -webkit-backdrop-filter: blur(32px);
        overflow: hidden;
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.04) inset,
          0 32px 80px -20px rgba(0, 0, 0, 0.7),
          0 0 60px -20px rgba(139, 92, 246, 0.1);
        animation: cardIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      @keyframes cardIn {
        from { opacity: 0; transform: translateY(24px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0)   scale(1); }
      }

      /* Inner glow ring (top edge highlight) */
      .cert-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 10%;
        width: 80%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.6), transparent);
        border-radius: 100%;
      }

      /* ─── FORM VIEW ─────────────────────────────────────────── */
      #form-view {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0;
      }

      /* Badge */
      .powered-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 100px;
        border: 1px solid rgba(168, 85, 247, 0.3);
        background: rgba(168, 85, 247, 0.08);
        font-size: 0.72rem;
        font-weight: 700;
        color: #c084fc;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 28px;
      }

      /* Logo */
      .cert-logo {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        object-fit: cover;
        margin-bottom: 24px;
        filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.45));
        animation: float 5s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
      }

      /* Title */
      .cert-title {
        font-size: 2.4rem;
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.04em;
        background: linear-gradient(160deg, #ffffff 30%, #c084fc 70%, #8b5cf6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
      }

      /* Subtitle */
      .cert-subtitle {
        font-size: 0.97rem;
        color: #64748b;
        font-weight: 400;
        line-height: 1.5;
        margin-bottom: 36px;
        max-width: 320px;
      }

      /* ─── INPUT ─────────────────────────────────────────────── */
      .input-group {
        width: 100%;
        margin-bottom: 16px;
        position: relative;
      }

      .phone-input {
        width: 100%;
        padding: 18px 24px;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        font-size: 1.15rem;
        font-weight: 600;
        color: #f8fafc;
        text-align: center;
        letter-spacing: 0.06em;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        outline: none;
        font-family: 'Inter', sans-serif;
      }

      .phone-input::placeholder {
        color: #334155;
        font-weight: 500;
        letter-spacing: 0;
        font-size: 1rem;
      }

      .phone-input:focus {
        border-color: rgba(168, 85, 247, 0.55);
        background: rgba(15, 23, 42, 0.85);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.12);
      }

      /* ─── BUTTON ─────────────────────────────────────────────── */
      .cert-btn {
        width: 100%;
        padding: 18px 24px;
        background: linear-gradient(135deg, #7c3aed 0%, #9333ea 50%, #7c3aed 100%);
        background-size: 200% auto;
        border: none;
        border-radius: 16px;
        font-size: 1rem;
        font-weight: 700;
        color: #ffffff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        letter-spacing: 0.01em;
        transition: transform 0.2s, box-shadow 0.2s, background-position 0.4s;
        box-shadow: 0 8px 24px rgba(139, 92, 246, 0.35);
        position: relative;
        overflow: hidden;
        font-family: 'Inter', sans-serif;
      }

      .cert-btn::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, transparent 60%);
        pointer-events: none;
        border-radius: 16px;
      }

      .cert-btn:not(:disabled):hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 32px rgba(139, 92, 246, 0.5);
        background-position: right center;
      }

      .cert-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.15);
      }

      .cert-btn.loading {
        background: linear-gradient(90deg, #7c3aed 0%, #a855f7 30%, #7c3aed 60%, #a855f7 90%);
        background-size: 300% 100%;
        animation: shimmer 1.6s infinite linear;
        pointer-events: none;
      }

      @keyframes shimmer {
        0%   { background-position: -300% 0; }
        100% { background-position: 300% 0; }
      }

      .btn-spinner {
        display: none;
        width: 18px;
        height: 18px;
        border: 2.5px solid rgba(255, 255, 255, 0.25);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        flex-shrink: 0;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      /* ─── ERROR ─────────────────────────────────────────────── */
      .error-box {
        display: none;
        align-items: flex-start;
        gap: 10px;
        margin-top: 16px;
        padding: 14px 16px;
        border: 1px solid rgba(248, 113, 113, 0.2);
        border-radius: 12px;
        background: rgba(239, 68, 68, 0.06);
        font-size: 0.875rem;
        color: #fca5a5;
        line-height: 1.5;
        text-align: left;
        width: 100%;
        animation: fadeUp 0.3s ease both;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ─── SUCCESS VIEW ──────────────────────────────────────── */
      #success-view {
        display: none;
        flex-direction: column;
        align-items: center;
        text-align: center;
        animation: cardIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .success-ring {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 24px;
        box-shadow: 0 0 30px rgba(16, 185, 129, 0.15);
        animation: pulseBadge 2.4s ease-in-out infinite;
      }

      @keyframes pulseBadge {
        0%, 100% { box-shadow: 0 0 20px rgba(16, 185, 129, 0.12); }
        50%       { box-shadow: 0 0 40px rgba(16, 185, 129, 0.28); }
      }

      .success-title {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f8fafc;
        margin-bottom: 8px;
      }

      .success-desc {
        font-size: 0.92rem;
        color: #64748b;
        line-height: 1.55;
        margin-bottom: 32px;
        max-width: 320px;
      }

      .action-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
      }

      .btn-linkedin {
        width: 100%;
        padding: 17px 24px;
        background: linear-gradient(135deg, #0a66c2 0%, #1d7bc4 100%);
        border: none;
        border-radius: 14px;
        font-size: 0.97rem;
        font-weight: 700;
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 8px 20px rgba(10, 102, 194, 0.35);
        font-family: 'Inter', sans-serif;
      }

      .btn-linkedin:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(10, 102, 194, 0.5);
      }

      .btn-ghost {
        width: 100%;
        padding: 15px 24px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        font-size: 0.92rem;
        font-weight: 600;
        color: #94a3b8;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
        font-family: 'Inter', sans-serif;
      }

      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.15);
        color: #e2e8f0;
        transform: translateY(-1px);
      }

      .reset-link {
        display: inline-block;
        margin-top: 24px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #7c3aed;
        cursor: pointer;
        text-decoration: none;
        transition: color 0.2s;
      }

      .reset-link:hover { color: #a855f7; }

      /* ─── CERT PREVIEW ──────────────────────────────────────── */
      .cert-preview-wrap {
        width: 100%;
        margin-bottom: 28px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(139, 92, 246, 0.22);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.04) inset;
        position: relative;
        animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .cert-preview-wrap::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, rgba(139, 92, 246, 0.06), transparent 60%);
        pointer-events: none;
        z-index: 1;
      }

      #cert-preview-img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 15px;
        object-fit: cover;
      }

      /* LinkedIn attach hint */
      .li-hint {
        display: none;
        align-items: flex-start;
        gap: 8px;
        margin-top: 10px;
        padding: 12px 14px;
        border: 1px solid rgba(10, 102, 194, 0.25);
        border-radius: 12px;
        background: rgba(10, 102, 194, 0.07);
        font-size: 0.82rem;
        color: #93c5fd;
        line-height: 1.5;
        text-align: left;
        animation: fadeUp 0.3s ease both;
      }

      /* ─── RESPONSIVE ────────────────────────────────────────── */
      @media (max-width: 600px) {
        .cert-card { padding: 36px 24px; }
        .cert-title { font-size: 1.85rem; }
      }

      /* Desktop-specific: ensure body takes full viewport height */
      @media (min-width: 601px) {
        body { min-height: 100vh; }
        .cert-page { min-height: calc(100vh - 64px); }
      }
    </style>
  </head>
  <body>

    <!-- ── NAVIGATION ─────────────────────────────────────────── -->
    <nav class="cert-nav">
      <a href="/" class="cert-nav-brand">
        <img
          src="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png"
          alt="GradSkills"
          class="cert-nav-logo"
        />
        <span class="cert-nav-name">GradSkills</span>
        <span class="cert-nav-sub">Summership 2026</span>
      </a>
    </nav>

    <%- include("partials/flash") %>

    <!-- ── MAIN PAGE ──────────────────────────────────────────── -->
    <main class="cert-page">
      <div class="cert-card">

        <!-- ── FORM VIEW ──────────────────────────────────────── -->
        <div id="form-view">
          <span class="powered-badge">✦ Powered by GradSkills</span>

          <img
            src="https://image2url.com/r2/default/images/1772364686444-9b7d74ff-802f-4f36-8b7e-d7daaedab981.png"
            alt="GradSkills"
            class="cert-logo"
          />

          <h1 class="cert-title">Summership E&#8209;Certificate</h1>
          <p class="cert-subtitle">
            Access and download your official participation certificate instantly.
          </p>

          <div class="input-group">
            <input
              type="tel"
              id="mobile-number-input"
              class="phone-input"
              placeholder="Registered Mobile Number"
              maxlength="10"
              autocomplete="off"
            />
          </div>

          <button type="button" id="submit-btn" class="cert-btn" disabled>
            <span class="btn-spinner" id="btn-loader"></span>
            <span id="btn-text">Generate Certificate</span>
          </button>

          <div class="error-box" id="error-panel">
            <span>⚠</span>
            <span id="error-msg-text"></span>
          </div>
        </div>

        <!-- ── SUCCESS VIEW ───────────────────────────────────── -->
        <div id="success-view">
          <div class="success-ring">🏆</div>

          <h2 class="success-title">Certificate Ready</h2>
          <p class="success-desc">
            Your Summership participation certificate has been generated and downloaded to your device.
          </p>

          <div class="action-stack">
            <a href="#" id="linkedin-share-link" class="btn-linkedin" target="_blank" rel="noopener">
              <span>in</span> Share on LinkedIn
            </a>
            <button type="button" id="download-pdf-btn" class="btn-ghost">
              Download PDF Version
            </button>
            <button type="button" id="download-jpg-btn" class="btn-ghost">
              Download JPG Again
            </button>
          </div>

          <span class="reset-link" id="reset-form-btn">← Use a different number</span>
        </div>

      </div>
    </main>

    <!-- Hidden canvas for certificate generation -->
    <canvas id="cert-canvas" style="display:none;"></canvas>
    <img id="cert-template-img" src="/images/certificate-template.jpg" style="display:none;" />

    <script>
      (function () {
        const mobileInput   = document.getElementById('mobile-number-input');
        const submitBtn     = document.getElementById('submit-btn');
        const btnLoader     = document.getElementById('btn-loader');
        const btnText       = document.getElementById('btn-text');
        const formView      = document.getElementById('form-view');
        const successView   = document.getElementById('success-view');
        const resetBtn      = document.getElementById('reset-form-btn');
        const errorPanel    = document.getElementById('error-panel');
        const errorText     = document.getElementById('error-msg-text');
        const certCanvas    = document.getElementById('cert-canvas');
        const certImg       = document.getElementById('cert-template-img');
        const pdfBtn        = document.getElementById('download-pdf-btn');
        const jpgBtn        = document.getElementById('download-jpg-btn');
        const liBtn         = document.getElementById('linkedin-share-btn');
        const liHint        = document.getElementById('li-hint');
        const previewImg    = document.getElementById('cert-preview-img');

        let teamName     = '';
        let leaderName   = '';
        let problemTitle = '';
        let liPostText   = '';

        /* ── Preload Montserrat for canvas ── */
        (async function () {
          try {
            const f = new FontFace('Montserrat', 'url(https://fonts.gstatic.com/s/montserrat/v26/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2)');
            await f.load();
            document.fonts.add(f);
          } catch (_) {}
        })();

        function validMobile(n) { return /^[6-9]\d{9}$/.test(n); }

        mobileInput.addEventListener('input', function () {
          errorPanel.style.display = 'none';
          submitBtn.disabled = !validMobile(this.value.trim());
        });

        /* ── Draw certificate on canvas ── */
        function drawCert() {
          return new Promise(function (resolve) {
            function draw() {
              const ctx = certCanvas.getContext('2d');
              const w   = certImg.naturalWidth;
              const h   = certImg.naturalHeight;
              certCanvas.width  = w;
              certCanvas.height = h;
              ctx.drawImage(certImg, 0, 0, w, h);

              const display  = teamName || leaderName || 'Participant';
              const fontSize = Math.floor(w * 0.045);
              ctx.font         = 'bold ' + fontSize + "px 'Montserrat', sans-serif";
              ctx.fillStyle    = '#111827';
              ctx.textAlign    = 'center';
              ctx.textBaseline = 'bottom';
              ctx.fillText(display, w / 2, h * 0.465);
              resolve();
            }
            if (certImg.complete) { draw(); }
            else                  { certImg.onload = draw; }
          });
        }

        function fname() {
          return 'GradSkills_Summership_Certificate_' +
            (teamName || leaderName || 'Participant').replace(/\s+/g, '_');
        }

        function downloadJpg() {
          const a = document.createElement('a');
          a.href     = certCanvas.toDataURL('image/jpeg', 1.0);
          a.download = fname() + '.jpg';
          a.click();
        }

        function downloadPdf() {
          const { jsPDF } = window.jspdf;
          const pdf = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });
          pdf.addImage(certCanvas.toDataURL('image/jpeg', 1.0), 'JPEG', 0, 0, 297, 210);
          pdf.save(fname() + '.pdf');
        }

        /* ── Main generate handler ── */
        submitBtn.addEventListener('click', async function () {
          const mobile = mobileInput.value.trim();
          if (!validMobile(mobile)) {
            showError('Enter a valid 10-digit registered mobile number.');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.classList.add('loading');
          btnLoader.style.display = 'inline-block';
          btnText.textContent = 'Verifying…';
          errorPanel.style.display = 'none';

          try {
            const res  = await fetch('/api/fetch-selection?mobileNumber=' + encodeURIComponent(mobile));
            const data = await res.json();

            submitBtn.classList.remove('loading');
            btnLoader.style.display = 'none';
            btnText.textContent = 'Generate Certificate';
            submitBtn.disabled = false;

            if (!data.success) { showError(data.message); return; }

            teamName     = data.teamName   || '';
            leaderName   = data.leaderName || '';
            problemTitle = data.title      || '';

            /* Build LinkedIn caption */
            liPostText =
              '🎉 I am thrilled to share that I have officially locked my Problem Statement ' +
              'and received my E-Certificate from the GradSkills Summership Challenge 2026! 🚀🎓\n\n' +
              'Our team is working on: "' + problemTitle + '" — can\'t wait to build, learn, and ship! 💡\n\n' +
              'Huge thanks to @GradSkills for this incredible opportunity! 🌟\n\n' +
              '#GradSkills #Summership2026 #Hackathon #Innovation #BuildInPublic';

            localStorage.setItem('cert_claim_mobile', mobile);

            /* Draw, show preview, then auto-download */
            await drawCert();
            const dataUrl = certCanvas.toDataURL('image/jpeg', 1.0);
            previewImg.src = dataUrl;          /* show preview */
            downloadJpg();                     /* auto-download */

            formView.style.display    = 'none';
            successView.style.display = 'flex';

          } catch (_) {
            submitBtn.classList.remove('loading');
            btnLoader.style.display = 'none';
            btnText.textContent = 'Generate Certificate';
            submitBtn.disabled = false;
            showError('Network error. Please check your connection and try again.');
          }
        });

        /* ── LinkedIn share: re-download cert + open composer + show attach hint ── */
        liBtn.addEventListener('click', function () {
          downloadJpg();   /* ensure cert is in downloads */
          liHint.style.display = 'flex';
          const url = 'https://www.linkedin.com/feed/?shareActive=true&text=' + encodeURIComponent(liPostText);
          window.open(url, '_blank', 'noopener,noreferrer');
        });

        function showError(msg) {
          errorText.textContent    = msg;
          errorPanel.style.display = 'flex';
        }

        resetBtn.addEventListener('click', function () {
          mobileInput.value         = '';
          submitBtn.disabled        = true;
          errorPanel.style.display  = 'none';
          liHint.style.display      = 'none';
          successView.style.display = 'none';
          formView.style.display    = 'flex';
        });

        jpgBtn.addEventListener('click', downloadJpg);
        pdfBtn.addEventListener('click', downloadPdf);

        /* Restore cached number */
        const cached = localStorage.getItem('cert_claim_mobile');
        if (cached) {
          mobileInput.value  = cached;
          submitBtn.disabled = !validMobile(cached);
        }
      })();

    </script>
  </body>
</html>
